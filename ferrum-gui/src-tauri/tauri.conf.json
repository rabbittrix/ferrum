{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ferrum",
  "version": "0.1.0",
  "identifier": "com.rabbittrix.ferrum",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Ferrum — Infrastructure Dashboard",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "appimage"],
    "icon": ["icons/icon.png"],
    "publisher": "Roberto de Souza",
    "shortDescription": "Next-generation Infrastructure as Code",
    "longDescription": "Ferrum — high-performance, memory-safe IaC tool written in Rust."
  }
}
